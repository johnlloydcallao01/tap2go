{
  "name": "@encreasl/web-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true next build",
    "dev": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true next dev -p 3003",
    "dev:turbo": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true next dev --turbopack -p 3003",
    "lint": "eslint .",
    "start": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true next start -p 3003",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@encreasl/redux": "workspace:*",
    "@vercel/edge-config": "^1.4.3",
    "next": "16.0.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@encreasl/env": "workspace:*",
    "@encreasl/eslint-config": "workspace:*",
    "@encreasl/typescript-config": "workspace:*",
    "@encreasl/ui": "workspace:*",
    "@eslint/js": "^9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "autoprefixer": "^10.4.14",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "postcss": "^8.4.21",
    "tailwindcss": "3.3.2",
    "turbo": "^2.0.0",
    "typescript": "^5"
  }
